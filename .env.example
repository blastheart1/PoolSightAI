ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required for Voice Note transcription (/projects/[id] → Voice Note tab)
# Used by /api/transcribe → OpenAI Whisper (whisper-1 model)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
# Optional: Neon Postgres for projects + AI analysis (Phase 3+)
# Use DATABASE_URL or NEON_DATABASE_URL
NEON_DATABASE_URL=postgresql://user:password@neon-host/dbname
DATABASE_URL=postgresql://user:password@neon-host/dbname

# Optional: Trello API for /trello (Current Project board, daily report)
# Get key and token from https://trello.com/power-ups/admin (API Key tab, then Token link)
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_TOKEN=your-trello-api-token
# Optional: board id or shortLink (e.g. vsMJZfDD from https://trello.com/b/vsMJZfDD/current-production).
# If set, this board is used instead of searching by name "Current Project" / "Current Production".
# TRELLO_BOARD_ID=vsMJZfDD

# Webhook secret for Zapier contract email ingestion (/api/webhooks/contract-email)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-secret-here

